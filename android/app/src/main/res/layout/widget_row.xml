<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="bottom"
    android:paddingTop="3dp"
    android:paddingBottom="3dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="bottom">

        <TextView
            android:id="@+id/row_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_primary"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Order: city – offset – label – marker. Only the relevant views are
             visible per row, so the collapsed ones don't affect spacing. -->

        <!-- Offset span, e.g. "Vancouver  −8 hrs" (non-local rows). -->
        <TextView
            android:id="@+id/row_offset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:visibility="gone" />

        <TextView
            android:id="@+id/row_local_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="Local time"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:visibility="gone" />

        <TextView
            android:id="@+id/row_device_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="· Device time"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/row_pin"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="5dp"
            android:src="@drawable/ic_pin_local"
            android:visibility="gone"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/row_device"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="📱"
            android:textSize="11sp"
            android:includeFontPadding="false"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Day label sits immediately before the time. -->
    <TextView
        android:id="@+id/row_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- No minWidth: the right-packed group already shares a right edge, so
         tabular digits keep colons aligned without padding the box. -->
    <TextClock
        android:id="@+id/row_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/widget_text_primary"
        android:textSize="15sp"
        android:fontFeatureSettings="tnum"
        android:format12Hour="h:mm"
        android:format24Hour="HH:mm" />

    <TextClock
        android:id="@+id/row_period"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:minWidth="18dp"
        android:gravity="end"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp"
        android:fontFeatureSettings="tnum"
        android:format12Hour="a"
        android:format24Hour="" />
</LinearLayout>
